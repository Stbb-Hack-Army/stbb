local abilityKeys = {
    { key = Enum.KeyCode.Q, name = "Q", cooldown = 8 },
    { key = Enum.KeyCode.E, name = "E", cooldown = 12 },
    { key = Enum.KeyCode.R, name = "R", cooldown = 20 },
    { key = Enum.KeyCode.T, name = "T", cooldown = 25 },
    { key = Enum.KeyCode.G, name = "G", cooldown = 15 },
    { key = Enum.KeyCode.H, name = "H", cooldown = 18 },
    { key = Enum.KeyCode.J, name = "J", cooldown = 30 },
    { key = Enum.KeyCode.X, name = "X", cooldown = 10 },
    { key = Enum.KeyCode.C, name = "C", cooldown = 10 },
    { key = Enum.KeyCode.V, name = "V", cooldown = 22 },
}

local abilityCooldowns = {}
for _, ab in ipairs(abilityKeys) do
    abilityCooldowns[ab.name] = { lastUsed = 0, cooldown = ab.cooldown }
end

local function isAbilityReady(name)
    local e = abilityCooldowns[name]
    if not e then return true end
    return tick() - e.lastUsed >= e.cooldown
end

local function markUsed(name)
    if abilityCooldowns[name] then
        abilityCooldowns[name].lastUsed = tick()
    end
end

local function getCooldownText(name)
    local e = abilityCooldowns[name]
    if not e then return "?" end
    local remaining = e.cooldown - (tick() - e.lastUsed)
    if remaining <= 0 then return "Ready" end
    return string.format("%.1fs", remaining)
end

