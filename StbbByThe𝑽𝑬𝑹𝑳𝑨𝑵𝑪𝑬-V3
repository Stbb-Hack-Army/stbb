local function makeSection(parent, yPos, height, bgColor)
    local f = Instance.new("Frame", parent)
    f.Size = UDim2.new(1, -20, 0, height)
    f.Position = UDim2.new(0, 10, 0, yPos)
    f.BackgroundColor3 = bgColor or Color3.fromRGB(18, 12, 22)
