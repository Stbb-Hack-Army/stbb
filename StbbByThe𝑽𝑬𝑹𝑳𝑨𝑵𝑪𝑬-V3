local function enableMobileSpoofV2()
    pcall(function()
        -- الطريقة الصح عبر الـ CoreGui modules
        local RobloxGui = game:GetService("CoreGui"):WaitForChild("RobloxGui")
        
        -- 1. SetSmallTouchDevice
        local setSmall = RobloxGui.Modules:FindFirstChild("SetSmallTouchDevice", true)
        if setSmall then
            pcall(function() require(setSmall)(true) end)
        end
        
        -- 2. SetIsSmallTouchScreen  
        local setTouch = RobloxGui.Modules:FindFirstChild("SetIsSmallTouchScreen", true)
        if setTouch then
            pcall(function() require(setTouch)(true) end)
        end

        -- 3. TouchControls - فعّل الـ touch controls
        local touchControls = RobloxGui.Modules:FindFirstChild("TouchControls", true)
        if touchControls then
            pcall(function() require(touchControls) end)
        end

        -- 4. shouldRejectMultiTouch - خليها false
        local rejectMulti = RobloxGui.Modules:FindFirstChild("shouldRejectMultiTouch", true)
        if rejectMulti then
            pcall(function() require(rejectMulti)(false) end)
        end
    end)

    -- 5. metatable على UserInputService
    pcall(function()
        local uis = game:GetService("UserInputService")
        local mt = getrawmetatable(game)
        local oldIndex = mt.__index
        setreadonly(mt, false)
        mt.__index = newcclosure(function(self, key)
            if self == uis then
                if key == "TouchEnabled" then return true end
                if key == "GamepadEnabled" then return false end
                if key == "MouseEnabled" then return false end
                if key == "KeyboardEnabled" then return false end
            end
            return oldIndex(self, key)
        end)
        setreadonly(mt, true)
    end)

    -- 6. فعّل TouchGui مباشرة
    pcall(function()
        local CoreGui = game:GetService("CoreGui")
        local TouchGui = CoreGui:FindFirstChild("TouchGui")
        if not TouchGui then
            TouchGui = Instance.new("ScreenGui")
            TouchGui.Name = "TouchGui"
            TouchGui.Parent = CoreGui
        end
        TouchGui.Enabled = true

        local frame = TouchGui:FindFirstChild("TouchControlFrame")
        if frame then frame.Visible = true end
    end)

    -- 7. انتظر وشغّل الـ ControlModule
    pcall(function()
        local ControlModule = require(game:GetService("Players").LocalPlayer.PlayerScripts:WaitForChild("PlayerModule"):WaitForChild("ControlModule"))
        if ControlModule then
            ControlModule:Enable(true)
        end
    end)

    print("[STBB] Mobile Spoof V2 ON")
end

local function disableMobileSpoofV2()
    pcall(function()
        local mt = getrawmetatable(game)
        setreadonly(mt, false)
        -- ارجع الـ metatable لطبيعتها
        local uis = game:GetService("UserInputService")
        local oldIndex = mt.__index
        mt.__index = newcclosure(function(self, key)
            return oldIndex(self, key)
        end)
        setreadonly(mt, true)
    end)
    print("[STBB] Mobile Spoof V2 OFF")
end

