    for _, ab in ipairs(abilityKeys) do
        pcall(function()
            VIM:SendKeyEvent(true, ab.key, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, ab.key, false, game)
        end)
        task.wait(0.03)
    end
end

local HEAL_POS = Vector3.new(51, 8, -45)

local function buyHealth()
    if tick() - STATE.LastHeal < 8 then return end
    local hum = getActiveHumanoid()
    if hum and hum.Health / math.max(hum.MaxHealth, 1) > 0.7 then return end

    local root = getActiveRoot()
    if not root then return end

    root.CFrame = CFrame.new(HEAL_POS)
    task.wait(0.3)

    local pg = lp:FindFirstChild("PlayerGui")
    if pg then
        local gui003 = pg:FindFirstChild("003-A")
        if gui003 then
            local mainF = gui003:FindFirstChild("Main")
            if mainF then
                local healBtn = mainF:FindFirstChild("Heal")
                if healBtn then
                    local absPos = healBtn.AbsolutePosition
                    local absSize = healBtn.AbsoluteSize
                    local cx = absPos.X + absSize.X/2
                    local cy = absPos.Y + absSize.Y/2
                    pcall(function()
                        VIM:SendMouseButtonEvent(cx, cy, 0, true, game, 1)
                        task.wait(0.05)
                        VIM:SendMouseButtonEvent(cx, cy, 0, false, game, 1)
                    end)
                    for _, v in pairs(healBtn:GetDescendants()) do
                        if v:IsA("ClickDetector") then pcall(function() fireclickdetector(v) end) end
                        if v:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(v) end) end
                    end
                end
            end
        end
    end

    for _, p in pairs(Workspace:GetDescendants()) do
        if p:IsA("ProximityPrompt") then
            local txt = ((p.ActionText or "")..(p.ObjectText or "")):lower()
            if txt:find("heal") or txt:find("health") then
                pcall(function() fireproximityprompt(p) end)
                break
            end
        end
    end

    STATE.LastHeal = tick()
end

local COLLECT_KEYWORDS = {"coin","cash","xp","orb","drop","gem","gold","token","shard","money","reward"}
local COLLECT_RANGE = 55
local COLLECT_CD = 0.18

local function autoCollect()
    if tick() - STATE.LastCollect < COLLECT_CD then return end
    STATE.LastCollect = tick()
    local root = getActiveRoot()
    if not root then return end
    local rpos = root.Position

    local drops = {}
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and not obj.CanCollide and obj.Transparency < 0.95 then
            local nl = obj.Name:lower()
            local pnl = (obj.Parent and obj.Parent.Name:lower()) or ""
            local ok = false
            for _, kw in ipairs(COLLECT_KEYWORDS) do
                if nl:find(kw) or pnl:find(kw) then ok = true break end
            end
            if ok then
                local d = (obj.Position - rpos).Magnitude
                if d < COLLECT_RANGE then
                    table.insert(drops, { obj = obj, dist = d })
                end
            end
        end
    end

    table.sort(drops, function(a,b) return a.dist < b.dist end)

    for i = 1, math.min(5, #drops) do
        local obj = drops[i].obj
        if obj and obj.Parent then
            root.CFrame = CFrame.new(obj.Position + Vector3.new(0,4,0))
            for _, pr in pairs(obj:GetDescendants()) do
                if pr:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(pr) end) break end
            end
            if obj.Parent and obj.Parent:IsA("Model") then
                for _, pr in pairs(obj.Parent:GetDescendants()) do
                    if pr:IsA("ProximityPrompt") then pcall(function() fireproximityprompt(pr) end) break end
                end
            end
            task.wait(0.04)
        end
    end
end

local function handleRespawn()
    local root = getActiveRoot()
    if not root then return end
    local p1 = Vector3.new(611, -468, 529)
    if (root.Position - p1).Magnitude < 30 and tick() - STATE.LastRespawnTeleport > 8 then
        STATE.LastRespawnTeleport = tick()
        root.CFrame = CFrame.new(p1)
        task.wait(1)
        root.CFrame = CFrame.new(593, -468, 466)
        task.wait(3.5)
        root.CFrame = CFrame.new(560, -468, 466)
    end
end

local trackedHP = {}
local function trackKills(targets)
    local cur = {}
    for _, t in pairs(targets) do cur[t] = true end
    for enemy in pairs(trackedHP) do
        if not cur[enemy] or not enemy.Parent then
            STATE.TotalKills = STATE.TotalKills + 1
            trackedHP[enemy] = nil
        end
    end
    for _, t in pairs(targets) do
        local hum = t:FindFirstChildWhichIsA("Humanoid")
        if hum then trackedHP[t] = hum.Health end
    end
end

