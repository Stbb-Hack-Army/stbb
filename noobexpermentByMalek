    hb.Size = UDim2.new(1,0,1,0); hb.BackgroundTransparency = 1
    hb.Text = ""; hb.Parent = row
    hb.MouseButton1Click:Connect(function() set(not isOn) end)
    return set
end

-- ─── Slider مشترك ─────────────────────────────
local function createSlider(labelText, yPos, initVal, minVal, maxVal, onChange)
    local lbl = Instance.new("TextLabel")
    lbl.Size               = UDim2.new(1,-20,0,20)
    lbl.Position           = UDim2.new(0,10,0,yPos)
    lbl.BackgroundTransparency = 1
    lbl.Text               = labelText .. initVal
    lbl.TextColor3         = Color3.fromRGB(180,180,180)
    lbl.TextSize           = 12
    lbl.Font               = Enum.Font.Gotham
    lbl.TextXAlignment     = Enum.TextXAlignment.Left
    lbl.Parent             = content

    local bg = Instance.new("TextButton")
    bg.Size             = UDim2.new(1,-20,0,22)
    bg.Position         = UDim2.new(0,10,0,yPos+22)
    bg.BackgroundColor3 = Color3.fromRGB(38,38,52)
    bg.Text             = ""
    bg.BorderSizePixel  = 0
    bg.Parent           = content
    Instance.new("UICorner", bg).CornerRadius = UDim.new(0,11)

    local fill = Instance.new("Frame")
    fill.Size             = UDim2.new((initVal-minVal)/(maxVal-minVal),0,1,0)
    fill.BackgroundColor3 = Color3.fromRGB(80,150,240)
    fill.BorderSizePixel  = 0
    fill.Parent           = bg
    Instance.new("UICorner", fill).CornerRadius = UDim.new(0,11)

    local dragging = false
    local function update(x)
        local rel = math.clamp((x - bg.AbsolutePosition.X) / bg.AbsoluteSize.X, 0, 1)
        local val = math.floor(minVal + rel * (maxVal - minVal))
        fill.Size = UDim2.new(rel, 0, 1, 0)
        lbl.Text  = labelText .. val
        if onChange then onChange(val, rel) end
    end

    bg.MouseButton1Down:Connect(function() dragging = true; update(player:GetMouse().X) end)
    bg.TouchStarted:Connect(function(t) dragging = true; update(t.Position.X) end)
    bg.TouchMoved:Connect(function(t) if dragging then update(t.Position.X) end end)
    bg.TouchEnded:Connect(function() dragging = false end)
    UserInputService.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1
        or i.UserInputType == Enum.UserInputType.Touch then dragging = false end
    end)
    RunService.RenderStepped:Connect(function()
        if dragging then update(player:GetMouse().X) end
    end)
end

