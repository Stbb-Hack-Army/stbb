-- ─── Shoot ────────────────────────────────────
local function doShoot()
    local char = getChar(); if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then
            pcall(function() tool:Activate() end)
            for _, obj in ipairs(tool:GetDescendants()) do
                if obj:IsA("RemoteEvent") then
                    local aimPos = camera.CFrame.Position
                               + camera.CFrame.LookVector * 500
                    pcall(function() obj:FireServer(aimPos) end)
                end
            end
        end
    end
end

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    if inp.KeyCode == CFG.ShootKey then doShoot() end
end)

task.spawn(function()
    while true do
        task.wait(0.15)
        if states.autoShoot then doShoot() end
    end
end)

-- ─── Fly ──────────────────────────────────────
local flying   = false
local movement = Vector3.zero
local bv, bg, flyConn

local function stopFly()
    flying = false
    if bv      then bv:Destroy();        bv      = nil end
    if bg      then bg:Destroy();        bg      = nil end
    if flyConn then flyConn:Disconnect(); flyConn = nil end
    local hum = getHum()
    if hum then hum.PlatformStand = false end
end

local function startFly()
    local hrp = getHRP(); if not hrp then return end
    local hum = getHum(); if not hum then return end
    flying = true
    hum.PlatformStand = true
    bv = Instance.new("BodyVelocity")
    bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bv.Velocity = Vector3.zero; bv.Parent = hrp
    bg = Instance.new("BodyGyro")
    bg.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
    bg.D = 100; bg.P = 10000
    bg.CFrame = hrp.CFrame; bg.Parent = hrp
    flyConn = RunService.RenderStepped:Connect(function()
        if not flying or not bv or not bg then return end
        local cf = camera.CFrame
        bv.Velocity = (cf.LookVector * movement.Z
                     + cf.RightVector  * movement.X
                     + cf.UpVector     * movement.Y) * CFG.WalkSpeed
        if movement.Magnitude > 0 then
            bg.CFrame = CFrame.new(hrp.Position, hrp.Position + cf.LookVector)
        end
    end)
end

local function toggleFly()
    states.fly = not states.fly
    if states.fly then startFly() else stopFly() end
end

UserInputService.InputBegan:Connect(function(inp, gp)
    if gp then return end
    local k = inp.KeyCode
    if     k == Enum.KeyCode.F            then toggleFly()
    elseif k == Enum.KeyCode.W            then movement = Vector3.new(movement.X, movement.Y,  1)
    elseif k == Enum.KeyCode.S            then movement = Vector3.new(movement.X, movement.Y, -1)
    elseif k == Enum.KeyCode.A            then movement = Vector3.new(-1, movement.Y, movement.Z)
    elseif k == Enum.KeyCode.D            then movement = Vector3.new( 1, movement.Y, movement.Z)
    elseif k == Enum.KeyCode.Space        then movement = Vector3.new(movement.X,  1, movement.Z)
    elseif k == Enum.KeyCode.LeftControl  then movement = Vector3.new(movement.X, -1, movement.Z)
    end
end)

UserInputService.InputEnded:Connect(function(inp)
    local k = inp.KeyCode
    if     k == Enum.KeyCode.W or k == Enum.KeyCode.S then
        movement = Vector3.new(movement.X, movement.Y, 0)
    elseif k == Enum.KeyCode.A or k == Enum.KeyCode.D then
        movement = Vector3.new(0, movement.Y, movement.Z)
    elseif k == Enum.KeyCode.Space or k == Enum.KeyCode.LeftControl then
        movement = Vector3.new(movement.X, 0, movement.Z)
    end
end)

-- ─── Auto Farm ────────────────────────────────
local attackIndex = 0

local function pressKey(key)
    pcall(function()
        VirtualInputManager:SendKeyEvent(true,  key, false, game)
        task.wait(0.07)
        VirtualInputManager:SendKeyEvent(false, key, false, game)
    end)
end

local function doKick()
    local char = getChar(); if not char then return end
    for _, tool in ipairs(char:GetChildren()) do
        if tool:IsA("Tool") then pcall(function() tool:Activate() end) end
    end
end

local attacks = {
    function() doKick() end,
    function() pressKey(Enum.KeyCode.G) end,
    function() pressKey(Enum.KeyCode.R) end,
}

task.spawn(function()
    while true do
        task.wait(CFG.FarmDelay)
        if not states.autoFarm then continue end
        local char  = getChar()
        local myHRP = getHRP()
        local hum   = getHum()
        if not char or not myHRP or not hum then continue end
        local target, dist = getClosest()
        if not target or not target.Character then continue end
        local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if not tHRP then continue end
        if dist > CFG.FarmRange then
            hum:MoveTo(tHRP.Position)
        else
            attackIndex = (attackIndex % #attacks) + 1
            attacks[attackIndex]()
        end
    end
end)

-- ─── Aim Assist ───────────────────────────────
RunService.RenderStepped:Connect(function()
    if not states.aimAssist then return end
    local aiming = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
               or  UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    if not aiming then return end
    local target = getAssistTarget(); if not target then return end
    camera.CFrame = camera.CFrame:Lerp(
        CFrame.new(camera.CFrame.Position, target.Position),
        CFG.AssistStrength
    )
end)

