-- =============================================
-- مساعدات
-- =============================================
local function getMyChar() return player.Character end
local function getMyHum()
    local c = getMyChar(); return c and c:FindFirstChildOfClass("Humanoid")
end
local function getMyHRP()
    local c = getMyChar(); return c and c:FindFirstChild("HumanoidRootPart")
end
 
-- =============================================
-- أقرب عدو للشاشة
-- =============================================
local function getClosestOnScreen()
    local closest, best = nil, math.huge
    local cx = camera.ViewportSize.X / 2
    local cy = camera.ViewportSize.Y / 2
    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        if not p.Character then continue end
        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChild("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end
        local d3 = (hrp.Position - camera.CFrame.Position).Magnitude
        if d3 > CFG.AimMaxRange then continue end
        local sp, vis = camera:WorldToViewportPoint(hrp.Position)
        if not vis then continue end
        local d2 = math.sqrt((sp.X-cx)^2 + (sp.Y-cy)^2)
        if d2 < best then best = d2; closest = p end
    end
    return closest
end
 
-- أقرب عدو بالمسافة
local function getClosestByDist()
    local closest, best = nil, math.huge
    local myHRP = getMyHRP(); if not myHRP then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p == player then continue end
        if not p.Character then continue end
        local hrp = p.Character:FindFirstChild("HumanoidRootPart")
        local hum = p.Character:FindFirstChild("Humanoid")
        if not hrp or not hum or hum.Health <= 0 then continue end
        local d = (hrp.Position - myHRP.Position).Magnitude
        if d < best then best = d; closest = p end
    end
    return closest, best
end
 
-- =============================================
-- ESP - مربع أخضر حول الهدف
-- =============================================
local function clearHighlights()
    for p, h in pairs(highlights) do
        pcall(function() h:Destroy() end); highlights[p] = nil
    end
end
 
local function setHighlight(tgt)
    for p, h in pairs(highlights) do
        if p ~= tgt then pcall(function() h:Destroy() end); highlights[p] = nil end
    end
    if not tgt or highlights[tgt] or not tgt.Character then return end
    local h = Instance.new("Highlight")
    h.FillColor           = Color3.fromRGB(0, 255, 80)
    h.OutlineColor        = Color3.fromRGB(0, 255, 80)
    h.FillTransparency    = 0.78
    h.OutlineTransparency = 0
    h.DepthMode           = Enum.HighlightDepthMode.AlwaysOnTop
    h.Adornee             = tgt.Character
    h.Parent              = tgt.Character
    highlights[tgt]       = h
end
 
-- =============================================
-- ONE SHOT - محسّن بالكامل
-- يستخدم 3 طرق مع بعض
-- =============================================
local function killChar(char)
    if not char then return end
    -- تأكد إن هو عدو مو نفسك
    if char == getMyChar() then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum or hum.Health <= 0 then return end
 
    -- طريقة 1: مباشر
    pcall(function() hum.Health = 0 end)
    -- طريقة 2: TakeDamage
    pcall(function() hum:TakeDamage(math.huge) end)
    -- طريقة 3: كل Remote في الـ Character
    pcall(function()
        for _, v in ipairs(char:GetDescendants()) do
            if v:IsA("RemoteEvent") then
                pcall(function() v:FireServer("damage", 99999) end)
                pcall(function() v:FireServer(99999) end)
            end
        end
    end)
end
 
-- =============================================
-- AUTO SHOOT - يطلق تلقائياً على الهدف المقفول
-- =============================================
local function simulateShoot(targetChar)
    if not targetChar then return end
    local myChar = getMyChar()
    if not myChar then return end
    local myHRP  = getMyHRP()
    if not myHRP then return end
 
    local targetHRP  = targetChar:FindFirstChild("HumanoidRootPart")
    local targetHead = targetChar:FindFirstChild("Head")
    if not targetHRP then return end
 
    -- لو One Shot شغّال اقتله مباشرة
    if states.oneShot then
        killChar(targetChar)
        return
    end
 
    -- وإلا: محاكاة إطلاق حقيقي
    -- طريقة 1: انقل نفسك جنبه وأطلق
    local originalCF = myHRP.CFrame
    local offset = (myHRP.Position - targetHRP.Position).Unit * 4
    myHRP.CFrame = CFrame.new(targetHRP.Position + offset)
 
    -- أطلق كل Tool
    for _, tool in ipairs(myChar:GetChildren()) do
        if tool:IsA("Tool") then
            pcall(function() tool:Activate() end)
            for _, obj in ipairs(tool:GetDescendants()) do
                if obj:IsA("RemoteEvent") then
                    pcall(function()
                        obj:FireServer(
                            targetHead and targetHead.Position or targetHRP.Position,
                            targetChar,
                            targetHRP
                        )
                    end)
                end
            end
        end
    end
 
    -- ارجع لمكانك
    task.defer(function()
        if myHRP and myHRP.Parent then
            myHRP.CFrame = originalCF
        end
    end)
end
 
-- Loop الـ Auto Shoot
task.spawn(function()
    while true do
        task.wait(CFG.AutoShootDelay)
        if not states.autoShoot then continue end
        if not currentTarget or not currentTarget.Character then continue end
        local now = tick()
        if now - lastShootTime < CFG.AutoShootDelay then continue end
        lastShootTime = now
        simulateShoot(currentTarget.Character)
    end
end)
 
-- =============================================
-- Hook Tool للـ One Shot (لما تضرب يدوياً)
-- =============================================
local function hookTool(tool)
    local handle = tool:FindFirstChild("Handle")
    if handle then
        handle.Touched:Connect(function(hit)
            if not states.oneShot then return end
            local char = hit.Parent
            if char == getMyChar() then return end
            -- تأكد إنه لاعب
            for _, p in ipairs(Players:GetPlayers()) do
                if p.Character == char then killChar(char); break end
            end
        end)
    end
    -- عترض FireServer في الـ Tool
    for _, obj in ipairs(tool:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            pcall(function()
                local oldFire = obj.FireServer
                obj.FireServer = newcclosure(function(self, ...)
                    if states.oneShot and currentTarget and currentTarget.Character then
                        killChar(currentTarget.Character)
                    end
                    return oldFire(self, ...)
                end)
            end)
        end
    end
end
 
local function setupChar(char)
    char.ChildAdded:Connect(function(c)
        if c:IsA("Tool") then task.wait(0.05); hookTool(c) end
    end)
    for _, c in ipairs(char:GetChildren()) do
        if c:IsA("Tool") then hookTool(c) end
    end
end
 
