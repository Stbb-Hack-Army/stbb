-- =============================================
-- Auto Ability
-- =============================================
local abilityKeywords = {
    "ability","skill","power","spell","attack","dash","blast","strike",
    "punch","fire","ice","q","e","r","ultimate","قدرة","مهارة"
}
local function isAbility(tool)
    local name = tool.Name:lower()
    for _, kw in ipairs(abilityKeywords) do
        if name:find(kw) then return true end
    end
    for _, obj in ipairs(tool:GetDescendants()) do
        if obj:IsA("RemoteEvent") then return true end
    end
    return false
end
 
local function useAbility(tool)
    pcall(function() tool:Activate() end)
    for _, obj in ipairs(tool:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            pcall(function()
                local tgt = currentTarget and currentTarget.Character
                local hrp = tgt and tgt:FindFirstChild("HumanoidRootPart")
                obj:FireServer(hrp and hrp.Position or Vector3.new(0,0,0))
            end)
        end
    end
end
 
task.spawn(function()
    while true do
        task.wait(0.1)
        if not states.autoAbil then continue end
        local char = getMyChar(); if not char then continue end
        for _, obj in ipairs(char:GetChildren()) do
            if obj:IsA("Tool") and isAbility(obj) then useAbility(obj) end
        end
        local bp = player:FindFirstChild("Backpack")
        if bp then
            for _, obj in ipairs(bp:GetChildren()) do
                if obj:IsA("Tool") and isAbility(obj) then
                    local hum = getMyHum()
                    if hum then pcall(function() hum:EquipTool(obj) end) end
                    break
                end
            end
        end
    end
end)
 
-- =============================================
-- Auto Farm
-- =============================================
task.spawn(function()
    while true do
        task.wait(CFG.AutoFarmDelay)
        if not states.autoFarm then continue end
        local char  = getMyChar()
        local myHRP = getMyHRP()
        local hum   = getMyHum()
        if not char or not myHRP or not hum then continue end
 
        local target, dist = getClosestByDist()
        if not target or not target.Character then continue end
        local tHRP = target.Character:FindFirstChild("HumanoidRootPart")
        if not tHRP then continue end
 
        if dist > 6 then
            hum:MoveTo(tHRP.Position)
        else
            killChar(target.Character)
            if states.autoAbil then
                for _, obj in ipairs(char:GetChildren()) do
                    if obj:IsA("Tool") then useAbility(obj) end
                end
            end
        end
    end
end)
 
-- =============================================
-- RenderStepped: AimBot + Target Update
-- =============================================
RunService.RenderStepped:Connect(function()
    local enemy = getClosestOnScreen()
    currentTarget = enemy
 
    -- ESP: مربع أخضر لما الـ Aim Bot شغّال وفيه هدف
    if states.aimBot and enemy then
        setHighlight(enemy)
    else
        clearHighlights()
    end
 
    -- AimBot: حرّك الكاميرا
    if states.aimBot and enemy and enemy.Character then
        local head = enemy.Character:FindFirstChild("Head")
        local hrp  = enemy.Character:FindFirstChild("HumanoidRootPart")
        local pos  = head and head.Position or (hrp and hrp.Position)
        if pos then
            camera.CFrame = camera.CFrame:Lerp(
                CFrame.new(camera.CFrame.Position, pos), CFG.AimSmoothing)
        end
    end
end)
 
